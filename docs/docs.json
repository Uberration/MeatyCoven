{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Coven",
  "description": "Local-first runtime substrate for persistent AI familiars. Coven launches, supervises, and audits coding-agent harnesses inside explicit project boundaries, with a typed local socket API for clients like comux, OpenMeow, and the external OpenClaw plugin.",
  "theme": "mint",
  "icons": {
    "library": "lucide"
  },
  "logo": {
    "light": "/assets/opencoven-black.svg",
    "dark": "/assets/opencoven-white.svg"
  },
  "fonts": {
    "body": {
      "family": "Fragment Mono"
    },
    "heading": {
      "family": "DM Sans"
    }
  },
  "favicon": "/assets/opencoven-mark.svg",
  "colors": {
    "primary": "#7C5CFF",
    "dark": "#6E4BFF",
    "light": "#A78BFF"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "dark": "min-dark",
        "light": "min-light"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/OpenCoven/coven",
        "icon": "github"
      },
      {
        "label": "Releases",
        "href": "https://github.com/OpenCoven/coven/releases",
        "icon": "package"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/opencoven",
        "icon": "discord"
      }
    ]
  },
